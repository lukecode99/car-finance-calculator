{
  "expo": {
    "name": "Car Finance Calculator",
    "slug": "car-finance-calculator",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0D0D0D"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.lukeholder.carfinancecalc"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0D0D0D"
      },
      "package": "com.lukeholder.carfinancecalc"
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": []
  }
}
